{
  "name": "D1: Tool Use Under the Hood",
  "build": {
    "dockerfile": "../../.devcontainer-base/Dockerfile",
    "context": "../../.devcontainer-base"
  },
  "workspaceFolder": "/workspaces/01_tool_use",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/01_tool_use,type=bind,consistency=cached",
  "customizations": {
    "vscode": {
      "extensions": [
        "humao.rest-client",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "mounts": [],
  "runArgs": [
    "--hostname",
    "demo-01-tool-use"
  ]
}